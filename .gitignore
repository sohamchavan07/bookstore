# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-wal

# Ignore all disk-based storage.
/storage/*
!/storage/.keep

# Ignore public/assets
/public/assets

# Ignore master key for decrypting credentials and secrets.
/config/master.key
/config/credentials/*.key

# Ignore .env files
.env
.env.*

# Ignore MacOS files
.DS_Store

# Ignore local secrets
tmp/local_secret.txt
