<section class="auth-shell">
  <div class="auth-card">
    <div class="auth-header">
      <h1>OTP Login</h1>
      <p>Enter your email to receive a secure code</p>
    </div>
    
    <%= form_with url: create_otp_path, local: true, class: "auth-form" do |f| %>
      <div class="field">
        <%= f.label :email, "Email Address" %>
        <%= f.email_field :email, required: true, placeholder: "name@example.com", class: "" %>
      </div>
      
      <%= f.submit "Send Secure Code", class: "auth-submit" %>
    <% end %>

    <div class="auth-links">
      <p class="text-sm text-slate-500">Wait, I remember my password! <%= link_to "Sign in with password", new_user_session_path %></p>
    </div>
  </div>
</section>
