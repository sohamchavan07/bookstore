<section class="auth-shell">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Verify OTP</h1>
      <p>Enter the 6-digit code sent to <strong><%= @email %></strong></p>
    </div>
    
    <%= form_with url: validate_otp_path, local: true, class: "auth-form" do |f| %>
      <div class="field">
        <%= f.label :otp_code, "Security Code" %>
        <%= f.text_field :otp_code, required: true, maxlength: 6, placeholder: "000000", style: "text-align: center; font-size: 1.5rem; letter-spacing: 0.5rem; font-weight: 700;" %>
      </div>
      
      <%= f.submit "Verify & Sign In", class: "auth-submit" %>
    <% end %>

    <div class="auth-links">
      <p class="text-sm text-slate-500">Didn't receive the code? <%= link_to "Resend OTP", new_otp_path %></p>
    </div>
  </div>
</section>
