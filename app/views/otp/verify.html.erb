<div class="flex flex-col items-center justify-center min-h-screen bg-gray-100">
  <div class="w-full max-w-md p-8 bg-white rounded-lg shadow-md">
    <h1 class="text-2xl font-bold mb-6 text-center text-gray-800">Verify OTP</h1>
    <p class="mb-4 text-center text-gray-600">Enter the 6-digit code sent to <strong><%= @email %></strong></p>
    
    <%= form_with url: validate_otp_path, local: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :otp_code, "OTP Code", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :otp_code, required: true, maxlength: 6, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-center text-2xl tracking-widest focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      
      <div>
        <%= f.submit "Verify & Login", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= link_to "Resend OTP", new_otp_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>
</div>
