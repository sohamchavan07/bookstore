<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  .lfp-shell-wrap {
    background: #f5f1ea;
    min-height: calc(100vh - 220px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    font-family: "DM Sans", sans-serif;
  }

  .lfp-shell-wrap *, .lfp-shell-wrap *::before, .lfp-shell-wrap *::after {
    box-sizing: border-box;
  }

  .lfp-shell {
    width: 100%;
    max-width: 460px;
  }

  .lfp-wordmark {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 2rem;
    justify-content: center;
  }

  .lfp-wordmark-icon {
    width: 32px;
    height: 32px;
    background: #1a3d2b;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lfp-wordmark-name {
    font-family: "Cormorant Garamond", serif;
    font-size: 18px;
    font-weight: 600;
    color: #1a1a18;
    letter-spacing: .02em;
  }

  .lfp-card {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e8e2d8;
    padding: 2.5rem 2.5rem 2rem;
    box-shadow: 0 1px 3px rgba(26, 20, 10, .06), 0 8px 32px rgba(26, 20, 10, .06);
  }

  .lfp-icon-wrap {
    width: 52px;
    height: 52px;
    background: #f0f7f3;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .lfp-auth-header {
    margin-bottom: 2rem;
  }

  .lfp-auth-header h1 {
    font-family: "Cormorant Garamond", serif;
    font-size: 32px;
    font-weight: 600;
    color: #1a1a18;
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .lfp-auth-header p {
    font-size: 14px;
    color: #7a7368;
    font-weight: 300;
    line-height: 1.55;
  }

  .lfp-error-box {
    background: #fef2f0;
    border: 1px solid #f9cfc9;
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 1.5rem;
    font-size: 13px;
    color: #b04030;
  }

  .lfp-field {
    margin-bottom: 1.5rem;
  }

  .lfp-field label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #4a4640;
    margin-bottom: 8px;
  }

  .lfp-field input[type="email"] {
    width: 100%;
    height: 44px;
    border: 1.5px solid #ddd9d0;
    border-radius: 8px;
    padding: 0 14px;
    font-size: 14px;
    font-family: "DM Sans", sans-serif;
    color: #1a1a18;
    background: #faf8f5;
    transition: border-color .15s, background .15s, box-shadow .15s;
    outline: none;
  }

  .lfp-field input[type="email"]:focus {
    border-color: #1a3d2b;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(26, 61, 43, .08);
  }

  .lfp-field input::placeholder {
    color: #b8b3ac;
  }

  .lfp-submit-btn {
    width: 100%;
    height: 46px;
    background: #1a3d2b;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: .02em;
    cursor: pointer;
    transition: background .15s, transform .1s;
    margin-bottom: 1.75rem;
  }

  .lfp-submit-btn:hover {
    background: #163325;
  }

  .lfp-submit-btn:active {
    transform: scale(.99);
  }

  .lfp-back-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 13px;
    color: #7a7368;
  }

  .lfp-back-row a {
    color: #1a3d2b;
    font-weight: 500;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .lfp-back-row a:hover {
    text-decoration: underline;
  }

  .lfp-back-row a svg {
    flex-shrink: 0;
  }
</style>

<section class="lfp-shell-wrap">
  <div class="lfp-shell">
    <div class="lfp-wordmark">
      <div class="lfp-wordmark-icon">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <rect x="3" y="2" width="3" height="14" rx="1" fill="#a7c4b3" />
          <rect x="7.5" y="2" width="3" height="14" rx="1" fill="#d4e8dc" />
          <rect x="12" y="2" width="3" height="14" rx="1" fill="#fff" opacity="0.6" />
        </svg>
      </div>
      <span class="lfp-wordmark-name">LibraryShelf</span>
    </div>

    <div class="lfp-card">
      <div class="lfp-icon-wrap">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="11" width="18" height="11" rx="2" stroke="#1a3d2b" stroke-width="1.75" fill="none" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="#1a3d2b" stroke-width="1.75" stroke-linecap="round" fill="none" />
          <circle cx="12" cy="16" r="1.25" fill="#1a3d2b" />
        </svg>
      </div>

      <div class="lfp-auth-header">
        <h1>Forgot password?</h1>
        <p>Enter your email and we'll send you reset instructions.</p>
      </div>

      <% if resource.errors.any? %>
        <div class="lfp-error-box">
          <% resource.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <div class="lfp-field">
          <%= f.label :email, "Email Address" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@example.com" %>
        </div>

        <%= f.submit "Send Reset Link", class: "lfp-submit-btn" %>
      <% end %>

      <div class="lfp-back-row">
        <%= link_to new_session_path(resource_name) do %>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M10 3L5 8l5 5" stroke="#1a3d2b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Back to sign in
        <% end %>
      </div>
    </div>
  </div>
</section>
