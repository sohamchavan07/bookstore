<section class="auth-shell">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Reset Password</h1>
      <p>Set a new secure password for your account</p>
    </div>

    <% if resource.errors.any? %>
      <div class="auth-errors">
        <% resource.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <div class="field">
        <%= f.label :password, "New Password" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "••••••••" %>
        <% if @minimum_password_length %>
          <small class="auth-hint"><%= @minimum_password_length %> characters minimum</small>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, "Confirm New Password" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••" %>
      </div>

      <%= f.submit "Update Password", class: "auth-submit" %>
    <% end %>

    <div class="auth-links">
      <%= link_to "Back to sign in", new_session_path(resource_name) %>
    </div>
  </div>
</section>
