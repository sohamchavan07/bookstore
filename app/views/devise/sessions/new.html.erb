<section class="auth-shell">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Welcome back</h1>
      <p>Sign in to your library collection</p>
    </div>

    <% if resource.errors.any? %>
      <div class="auth-errors">
        <% resource.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="field">
        <%= f.label :email, "Email Address" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@example.com" %>
      </div>

      <div class="field">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <%= f.label :password %>
          <% if devise_mapping.recoverable? %>
            <%= link_to "Forgot?", new_password_path(resource_name), class: "text-xs font-medium text-indigo-600 hover:text-indigo-500" %>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="field field-inline">
          <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
          <%= f.label :remember_me, "Keep me signed in" %>
        </div>
      <% end %>

      <%= f.submit "Sign In", class: "auth-submit" %>
    <% end %>

    <div class="auth-divider">
      <span>Continue with</span>
    </div>

    <div class="auth-social-actions">
      <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, class: "auth-btn-social" do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span>Google</span>
      <% end %>

      <%= link_to new_otp_path, class: "auth-btn-social" do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
        <span>Email OTP</span>
      <% end %>
    </div>

    <div class="auth-links">
      <p class="text-sm text-slate-500">Don't have an account? <%= link_to "Create one for free", new_registration_path(resource_name) %></p>
    </div>
  </div>
</section>
