<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  .session-shell {
    width: 100%;
    min-height: calc(100vh - 220px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: #f5f1ea;
    font-family: "DM Sans", sans-serif;
  }

  .session-shell * {
    box-sizing: border-box;
  }

  .session-shell .shell {
    width: 100%;
    max-width: 460px;
  }

  .session-shell .wordmark {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.5rem;
    justify-content: center;
  }

  .session-shell .wordmark-icon {
    width: 32px;
    height: 32px;
    background: #1a3d2b;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .session-shell .wordmark-icon svg {
    display: block;
  }

  .session-shell .wordmark-name {
    font-family: "Cormorant Garamond", serif;
    font-size: 18px;
    font-weight: 600;
    color: #1a1a18;
    letter-spacing: 0.02em;
  }

  .session-shell .card {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e8e2d8;
    padding: 2.5rem 2.5rem 2rem;
    box-shadow: 0 1px 3px rgba(26, 20, 10, 0.06), 0 8px 32px rgba(26, 20, 10, 0.06);
  }

  .session-shell .auth-header {
    margin-bottom: 2rem;
  }

  .session-shell .auth-header h1 {
    font-family: "Cormorant Garamond", serif;
    font-size: 32px;
    font-weight: 600;
    color: #1a1a18;
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .session-shell .auth-header p {
    font-size: 14px;
    color: #7a7368;
    font-weight: 300;
  }

  .session-shell .error-box {
    background: #fef2f0;
    border: 1px solid #f9cfc9;
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 1.5rem;
    font-size: 13px;
    color: #b04030;
  }

  .session-shell .field {
    margin-bottom: 1.25rem;
  }

  .session-shell .field label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #4a4640;
    margin-bottom: 8px;
  }

  .session-shell .field-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .session-shell .field-header label {
    margin-bottom: 0;
  }

  .session-shell .forgot-link {
    font-size: 12px;
    font-weight: 400;
    color: #1a3d2b;
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0;
  }

  .session-shell .forgot-link:hover {
    text-decoration: underline;
  }

  .session-shell input[type="email"],
  .session-shell input[type="password"] {
    width: 100%;
    height: 44px;
    border: 1.5px solid #ddd9d0;
    border-radius: 8px;
    padding: 0 14px;
    font-size: 14px;
    font-family: "DM Sans", sans-serif;
    color: #1a1a18;
    background: #faf8f5;
    transition: border-color 0.15s, background 0.15s;
    outline: none;
  }

  .session-shell input[type="email"]:focus,
  .session-shell input[type="password"]:focus {
    border-color: #1a3d2b;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(26, 61, 43, 0.08);
  }

  .session-shell input::placeholder {
    color: #b8b3ac;
  }

  .session-shell .remember-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.5rem;
  }

  .session-shell .remember-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    border: 1.5px solid #ccc;
    border-radius: 4px;
    accent-color: #1a3d2b;
    cursor: pointer;
  }

  .session-shell .remember-row label {
    font-size: 13px;
    color: #5a5550;
    cursor: pointer;
    margin: 0;
    text-transform: none;
    letter-spacing: normal;
  }

  .session-shell .submit-btn {
    width: 100%;
    height: 46px;
    background: #1a3d2b;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    margin-bottom: 1rem;
  }

  .session-shell .submit-btn:hover {
    background: #163325;
  }

  .session-shell .submit-btn:active {
    transform: scale(0.99);
  }

  .session-shell .legal {
    font-size: 11.5px;
    color: #9a9590;
    text-align: center;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .session-shell .legal a {
    color: #4a7c5f;
    text-decoration: none;
  }

  .session-shell .legal a:hover {
    text-decoration: underline;
  }

  .session-shell .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1.25rem;
  }

  .session-shell .divider::before,
  .session-shell .divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: #e8e2d8;
  }

  .session-shell .divider span {
    font-size: 12px;
    color: #b0ab9f;
    font-weight: 400;
  }

  .session-shell .google-btn {
    width: 100%;
    height: 44px;
    background: #fff;
    border: 1.5px solid #ddd9d0;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #2a2722;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
    text-decoration: none;
    margin-bottom: 1.75rem;
  }

  .session-shell .google-btn:hover {
    border-color: #bbb5ac;
    background: #faf8f5;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
  }

  .session-shell .signup-row {
    text-align: center;
    font-size: 13px;
    color: #7a7368;
  }

  .session-shell .signup-row a {
    color: #1a3d2b;
    font-weight: 500;
    text-decoration: none;
  }

  .session-shell .signup-row a:hover {
    text-decoration: underline;
  }
</style>

<section class="session-shell">
  <div class="shell">
    <div class="wordmark">
      <div class="wordmark-icon">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <rect x="3" y="2" width="3" height="14" rx="1" fill="#a7c4b3" />
          <rect x="7.5" y="2" width="3" height="14" rx="1" fill="#d4e8dc" />
          <rect x="12" y="2" width="3" height="14" rx="1" fill="#fff" opacity="0.6" />
        </svg>
      </div>
      <span class="wordmark-name">LibraryShelf</span>
    </div>

    <div class="card">
      <div class="auth-header">
        <h1>Welcome back</h1>
        <p>Sign in to your library collection</p>
      </div>

      <% if resource.errors.any? %>
        <div class="error-box">
          <% resource.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="field">
          <%= f.label :email, "Email Address" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@example.com" %>
        </div>

        <div class="field">
          <div class="field-header">
            <%= f.label :password %>
            <% if devise_mapping.recoverable? %>
              <%= link_to "Forgot?", new_password_path(resource_name), class: "forgot-link" %>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="remember-row">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, "Keep me signed in" %>
          </div>
        <% end %>

        <%= f.submit "Continue", class: "submit-btn" %>
      <% end %>

      <p class="legal">
        By clicking Continue, you agree to our
        <%= link_to "Terms and Conditions", "#" %>.
      </p>

      <div class="divider"><span>Or</span></div>

      <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, class: "google-btn", form_class: "social-form" do %>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
        </svg>
        Continue with Google
      <% end %>

      <div class="signup-row">
        Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name) %>
      </div>
    </div>
  </div>
</section>
