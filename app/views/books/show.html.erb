<section class="container book-detail-shell">
  <article class="book-detail-card">
    <header class="book-detail-header">
      <div>
        <span class="section-kicker">Book details</span>
        <h1><%= @book.title %></h1>
      </div>
      <span class="book-price">₹<%= number_with_precision(@book.price, precision: 2) %></span>
    </header>

    <div class="book-detail-layout">
      <aside class="book-detail-meta">
        <p><i class="fa-solid fa-user-pen"></i> <%= @book.author %></p>
        <p><i class="fa-regular fa-calendar"></i> <%= @book.published_on || "Not set" %></p>
        <p><i class="fa-solid fa-tag"></i> <%= @book.category.try(:name) || "Uncategorized" %></p>
      </aside>

      <div class="book-detail-body">
        <h4>Description</h4>
        <p><%= @book.formatted_details.presence || "No additional description provided yet." %></p>
      </div>
    </div>

    <div class="book-detail-actions">
      <%= link_to edit_book_path(@book), class: "btn btn-primary" do %>
        <i class="fa-solid fa-pen"></i> Edit
      <% end %>
      <%= link_to books_path, class: "btn btn-outline" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to Collection
      <% end %>
    </div>
  </article>
</section>
