<div class="lp-wrap">
  <section class="lp-section" style="max-width: 650px;">
    <div style="margin-bottom: 3rem;">
      <span class="lp-kicker">New Entry</span>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; margin: 0.5rem 0;">Add a new title</h1>
      <p style="color: var(--lp-text-2); font-size: 15px;">Initialize a new record in your curated collection by providing the essential metadata below.</p>
    </div>

    <div class="lp-panel">
      <%= render "form", book: @book %>
    </div>

    <div style="margin-top: 2rem; display: flex; justify-content: center;">
      <%= link_to books_path, class: "lp-btn-ghost" do %>
        &larr; Discard and return
      <% end %>
    </div>
  </section>
</div>
