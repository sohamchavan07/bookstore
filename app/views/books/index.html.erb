<div class="py-12 lg:py-20">
  <div class="container">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between mb-12 gap-8">
      <div class="max-w-2xl">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-4">
          Library Collection
        </span>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white tracking-tight mb-4">
          Browse our <span class="text-slate-500 italic">curated</span> catalog
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed">
          Manage, explore, and curate your book collection with ease.
        </p>
      </div>
      <%= link_to new_book_path, class: "btn btn-primary px-6 h-12 shadow-lg shadow-indigo-500/20 flex-shrink-0" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        <span>Add New Book</span>
      <% end %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
      <article class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5">
        <span class="block text-slate-500 text-[10px] uppercase tracking-wider font-bold mb-1">Total Books</span>
        <strong class="text-2xl text-white font-bold"><%= @books.count %></strong>
      </article>
      <article class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5">
        <span class="block text-slate-500 text-[10px] uppercase tracking-wider font-bold mb-1">Latest Release</span>
        <strong class="text-2xl text-white font-bold"><%= @books.maximum(:published_on)&.year || "N/A" %></strong>
      </article>
      <article class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5">
        <span class="block text-slate-500 text-[10px] uppercase tracking-wider font-bold mb-1">Categories</span>
        <strong class="text-2xl text-white font-bold"><%= Category.count %></strong>
      </article>
      <article class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5">
        <span class="block text-slate-500 text-[10px] uppercase tracking-wider font-bold mb-1">System Health</span>
        <strong class="text-2xl text-emerald-400 font-bold">Optimal</strong>
      </article>
    </div>

    <div class="bg-slate-900/80 border border-slate-800 rounded-3xl p-6 lg:p-8 mb-12 backdrop-blur-sm">
      <%= form_with url: books_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-12 gap-6 items-end" do |f| %>
        <div class="md:col-span-5">
          <%= f.label :query, "Search Collection", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-3" %>
          <%= f.text_field :query, value: params[:query], placeholder: "Search by title or author...", class: "w-full bg-slate-950 border-slate-800 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-white rounded-xl h-12 px-4 transition-all" %>
        </div>

        <div class="md:col-span-4">
          <%= f.label :category_id, "Category Filter", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-3" %>
          <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: "All Categories", selected: params[:category_id] }, { class: "w-full bg-slate-950 border-slate-800 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-white rounded-xl h-12 px-4 transition-all" } %>
        </div>

        <div class="md:col-span-3 flex gap-3">
          <%= f.submit "Filter", class: "flex-grow bg-indigo-600 hover:bg-indigo-500 text-white font-bold h-12 rounded-xl transition-all cursor-pointer shadow-lg shadow-indigo-600/10" %>
          <% if params[:query].present? || params[:category_id].present? %>
            <%= link_to books_path, class: "w-12 h-12 flex items-center justify-center bg-slate-800 hover:bg-slate-700 text-slate-300 rounded-xl transition-all", title: "Clear Filters" do %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @books.each do |book| %>
        <article class="card group">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-16 h-20 bg-gradient-to-br from-slate-700 to-slate-900 rounded shadow-md flex-shrink-0 flex items-center justify-center p-1 text-center group-hover:scale-105 transition-transform">
              <span class="text-[8px] font-bold text-slate-500 uppercase leading-none"><%= book.title %></span>
            </div>
            <div class="min-w-0">
              <div class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest mb-1"><%= book.category.name %></div>
              <h3 class="text-lg font-bold text-white truncate group-hover:text-indigo-300 transition-colors"><%= book.title %></h3>
              <p class="text-slate-500 text-sm truncate"><%= book.author %></p>
            </div>
          </div>
          
          <div class="flex items-center justify-between mb-6 pb-6 border-b border-slate-700/50">
            <span class="text-xl font-bold text-emerald-400">₹<%= number_with_precision(book.price, precision: 2) %></span>
            <span class="px-2 py-1 bg-slate-900 rounded text-[10px] font-bold text-slate-500"><%= book.published_on&.year || "—" %></span>
          </div>
          
          <div class="flex items-center gap-2 mt-auto">
            <%= link_to book, class: "flex-grow h-10 flex items-center justify-center bg-slate-700/30 hover:bg-indigo-600 text-slate-300 hover:text-white rounded-lg transition-all text-sm font-bold" do %>
              View Details
            <% end %>
            <%= link_to edit_book_path(book), class: "w-10 h-10 flex items-center justify-center bg-slate-700/30 hover:bg-amber-500/20 hover:text-amber-500 text-slate-400 rounded-lg transition-all" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-5M16.123 3.877a2.121 2.121 0 013 3l-9.375 9.375a1.125 1.125 0 01-.483.272l-3 1 .971-2.912a1.125 1.125 0 01.272-.483l9.375-9.375z"></path></svg>
            <% end %>
            <%= link_to book, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "w-10 h-10 flex items-center justify-center bg-slate-700/30 hover:bg-rose-500/20 hover:text-rose-500 text-slate-400 rounded-lg transition-all" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
    
    <% if @books.empty? %>
      <div class="text-center py-20 bg-slate-900/30 rounded-3xl border border-dashed border-slate-800">
        <div class="w-16 h-16 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-600">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
        </div>
        <p class="text-slate-500 font-medium">No books found in the collection matching your criteria.</p>
        <%= link_to "Clear all filters", books_path, class: "text-indigo-400 font-bold text-sm mt-4 inline-block hover:text-indigo-300 transition-colors" if params[:query].present? || params[:category_id].present? %>
      </div>
    <% end %>
  </div>
</div>
