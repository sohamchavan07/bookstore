<div class="container">
  <div class="books-page-header">
    <div>
      <span class="section-kicker">Collection</span>
      <h1>Library Collection</h1>
      <p class="section-subtext">
        Browse, manage, and curate your catalog from a single place.
      </p>
    </div>
    <%= link_to new_book_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-plus"></i> Add New Book
    <% end %>
  </div>

  <div class="book-stats-strip">
    <article class="stat-chip">
      <span class="stat-chip-label">Books in catalog</span>
      <strong><%= @books.count %></strong>
    </article>
    <article class="stat-chip">
      <span class="stat-chip-label">Latest publish year</span>
      <strong><%= @books.map(&:published_on).compact.max&.year || "N/A" %></strong>
    </article>
  </div>

  <div class="card-grid book-card-grid">
    <% @books.each do |book| %>
      <article class="card">
        <h3 class="book-card-title"><%= book.title %></h3>
        <p class="book-card-author">
          <i class="fa-solid fa-user-pen"></i> <%= book.author %>
        </p>
        
        <div class="book-meta">
          <span class="book-price">₹<%= number_with_precision(book.price, precision: 2) %></span>
          <span class="book-card-year"><%= book.published_on&.year || "—" %></span>
        </div>
        
        <p class="book-card-summary">
          <%= truncate(book.formatted_details, length: 100) %>
        </p>

        <div class="card-actions">
          <%= link_to book, class: "btn btn-sm btn-outline", title: "View Details" do %>
            <i class="fa-regular fa-eye"></i> Show
          <% end %>
          <%= link_to edit_book_path(book), class: "btn btn-sm btn-ghost", title: "Edit Book" do %>
            <i class="fa-solid fa-pen"></i>
          <% end %>
          <%= link_to book, method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-ghost", style: "color: var(--error);", title: "Delete" do %>
            <i class="fa-solid fa-trash"></i>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
  
  <% if @books.empty? %>
    <div class="text-center mt-4">
      <p style="color: var(--text-muted);">No books found in the library.</p>
    </div>
  <% end %>
</div>
