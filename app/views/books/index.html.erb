<div class="lp-wrap">
  <div class="lp-features" style="padding-top: 3rem;">
    <span class="lp-sec-kicker">Library Collection</span>
    <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Browse our <em>curated</em> catalog</h2>
    <p style="color: var(--lp-text-2); font-size: 1.1rem; margin-bottom: 2rem;">
      Manage, explore, and curate your book collection with ease.
    </p>

    <div class="lp-actions" style="margin-bottom: 3rem;">
      <%= link_to new_book_path, class: "lp-btn-main" do %>
        + Add New Book
      <% end %>
    </div>

    <div class="lp-stats" style="margin-bottom: 3rem; border: none; padding-top: 0;">
      <div class="lp-stat" style="border-right: 1px solid var(--lp-border-soft); border-left: none; padding-left: 0;">
        <strong><%= @books.count %></strong>
        <small>Total Books</small>
      </div>
      <div class="lp-stat" style="border-right: 1px solid var(--lp-border-soft); border-left: none;">
        <strong><%= @books.maximum(:published_on)&.year || "N/A" %></strong>
        <small>Latest Release</small>
      </div>
      <div class="lp-stat" style="border-right: 1px solid var(--lp-border-soft); border-left: none;">
        <strong><%= Category.count %></strong>
        <small>Categories</small>
      </div>
      <div class="lp-stat" style="border-left: none;">
        <strong style="color: var(--lp-sage);">Optimal</strong>
        <small>System Health</small>
      </div>
    </div>

    <div class="lp-panel" style="margin-bottom: 3rem;">
      <p class="lp-panel-label" style="margin-bottom: 1.5rem;">Filters</p>
      <%= form_with url: books_path, method: :get, local: true, style: "display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;" do |f| %>
        <div style="flex: 2; min-width: 200px;">
          <%= f.label :query, "Search Collection", style: "display: block; font-size: 12px; font-weight: 500; margin-bottom: .5rem; color: var(--lp-text-2);" %>
          <%= f.text_field :query, value: params[:query], placeholder: "Search by title or author...", style: "width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid var(--lp-border); font-family: inherit; font-size: 14px; background: #faf8f5;" %>
        </div>

        <div style="flex: 2; min-width: 200px;">
          <%= f.label :category_id, "Category Filter", style: "display: block; font-size: 12px; font-weight: 500; margin-bottom: .5rem; color: var(--lp-text-2);" %>
          <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: "All Categories", selected: params[:category_id] }, { style: "width: 100%; padding: 10px 14px; border-radius: 8px; border: 1px solid var(--lp-border); font-family: inherit; font-size: 14px; background: #faf8f5;" } %>
        </div>

        <div style="flex: 1; display: flex; gap: 10px;">
          <%= f.submit "Filter", class: "lp-btn-main", style: "flex-grow: 1; margin: 0; padding: 11px 20px;" %>
          <% if params[:query].present? || params[:category_id].present? %>
            <%= link_to "Clear Filters", books_path, class: "lp-btn-ghost", style: "margin: 0; padding: 11px 20px;" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="lp-card-grid">
      <% @books.each do |book| %>
        <div class="lp-card">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px;">
            <h3 style="flex: 1; line-height: 1.25;"><%= book.title %></h3>
            <span style="font-size: 11px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--lp-sage); background: rgba(74,124,95,.08); padding: 3px 8px; border-radius: 12px; white-space: nowrap;"><%= book.category.name %></span>
          </div>
          
          <p style="margin: 0.5rem 0 1.5rem; font-size: 14px;"><strong>Author:</strong> <%= book.author %></p>
          
          <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--lp-border-soft); padding-top: 1rem; margin-bottom: 0.5rem;">
            <strong style="color: var(--lp-text-1); font-family: 'Cormorant Garamond', serif; font-size: 1.25rem;">₹<%= number_with_precision(book.price, precision: 2) %></strong>
            <small style="color: var(--lp-text-3); font-weight: 500;"><%= book.published_on&.year || "—" %></small>
          </div>

          <div style="display: flex; gap: 12px; border-top: 1px solid var(--lp-border-soft); padding-top: 1rem; margin-top: auto;">
            <%= link_to "View", book, class: "lp-card-link" %>
            <%= link_to "Edit", edit_book_path(book), class: "lp-card-link", style: "color: #b47828;" %>
            <%= link_to "Delete", book, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "lp-card-link", style: "color: #b91c1c;" %>
          </div>
        </div>
      <% end %>
    </div>
    
    <% if @books.empty? %>
      <div class="lp-panel" style="margin-top: 1.5rem; text-align: center; padding: 4rem 2rem;">
        <div style="width: 48px; height: 48px; background: var(--lp-border-soft); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 20px;">
          ∅
        </div>
        <p style="color: var(--lp-text-2); font-weight: 500;">No books found in the collection matching your criteria.</p>
        <% if params[:query].present? || params[:category_id].present? %>
          <%= link_to "Clear all filters", books_path, style: "display: inline-block; margin-top: 1rem; font-size: 13.5px; font-weight: 500; color: var(--lp-green); text-decoration: underline;" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
