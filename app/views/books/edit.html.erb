<% content_for :title, "Edit book" %>

<section class="book-form-shell">
  <div class="book-form-card">
    <div class="book-form-header">
      <span class="book-form-badge">Edit mode</span>
      <h1>Update "<%= @book.title %>"</h1>
      <p>Refine metadata, pricing, and publication details without losing history.</p>
    </div>

    <%= render "form", book: @book %>

    <div class="book-form-footer">
      <%= link_to @book, class: "btn btn-outline" do %>
        <i class="fa-regular fa-eye"></i> View Book
      <% end %>
      <%= link_to books_path, class: "btn btn-ghost" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to Books
      <% end %>
    </div>
  </div>
</section>
