<div class="lp-wrap">
  <section class="lp-section" style="max-width: 650px;">
    <div style="margin-bottom: 3rem;">
      <span class="lp-kicker">Modification Request</span>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; margin: 0.5rem 0;">Update selection</h1>
      <p style="color: var(--lp-text-2); font-size: 15px;">Refine metadata, pricing, and publication details for <em>"<%= @book.title %>"</em>.</p>
    </div>

    <div class="lp-panel">
      <%= render "form", book: @book %>
    </div>

    <div style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center;">
      <%= link_to @book, class: "lp-btn-ghost" do %>
        View current record
      <% end %>
      <%= link_to books_path, class: "lp-btn-ghost" do %>
        &larr; Cancel and return
      <% end %>
    </div>
  </section>
</div>
