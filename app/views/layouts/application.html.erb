<!DOCTYPE html>
<html class="h-full scroll-smooth">
  <head>
    <title>BookStore | Premium Collection</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% auth_standalone_page = devise_controller? && ((controller_name == "sessions" && action_name == "new") || (controller_name == "registrations" && action_name == "new") || (controller_name == "passwords" && action_name == "new")) %>
  <body class="h-full flex flex-col antialiased">
    
    <% unless auth_standalone_page %>
      <header class="lp-nav">
        <div class="lp-nav-container">
          <%= link_to "BookStore", root_path, class: "lp-logo" %>
          
          <nav class="lp-nav-links">
            <%= link_to "Browse", books_path, class: "lp-nav-link" %>
            <% if user_signed_in? %>
              <%= link_to "Dashboard", dashboard_path, class: "lp-nav-link" %>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "lp-nav-link bg-transparent border-0 cursor-pointer p-0 font-medium" %>
            <% else %>
              <%= link_to "Login", new_user_session_path, class: "lp-nav-link" %>
              <%= link_to "Get Started", new_user_registration_path, class: "lp-btn-main" %>
            <% end %>
          </nav>
        </div>
      </header>
    <% end %>

    <!-- Flash Messages -->
    <div class="lp-wrap">
      <% if notice %>
        <div class="container py-4">
          <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-lg text-sm font-medium">
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="container py-4">
          <div class="bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-lg text-sm font-medium">
            <%= alert %>
          </div>
        </div>
      <% end %>
    </div>

    <main class="flex-grow">
      <%= yield %>
    </main>

    <% unless auth_standalone_page %>
      <footer class="lp-footer">
        <div class="lp-footer-container">
          <div class="lp-footer-brand">
            <%= link_to "BookStore", root_path, class: "lp-logo" %>
            <p>The premium destination for book curators and digital library enthusiasts. Experience a seamless way to manage your collection.</p>
          </div>
          <div>
            <h4 class="lp-footer-heading">Navigation</h4>
            <div class="lp-footer-links">
              <%= link_to "Browse Books", books_path, class: "lp-footer-link" %>
              <%= link_to "API Documentation", "#", class: "lp-footer-link" %>
            </div>
          </div>
          <div>
            <h4 class="lp-footer-heading">Connect</h4>
            <div class="lp-footer-links">
              <a href="https://github.com/sohamchavan07/bookstore" class="lp-footer-link" target="_blank">GitHub</a>
            </div>
          </div>
        </div>
        <div class="lp-footer-bottom">
          <span>&copy; <%= Time.current.year %> BookStore. All rights reserved.</span>
          <div class="flex gap-4">
            <a href="#" class="lp-footer-link">Privacy</a>
            <a href="#" class="lp-footer-link">Terms</a>
          </div>
        </div>
      </footer>
    <% end %>
  </body>
</html>
