<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>BookStore | Premium Collection</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full flex flex-col font-sans text-slate-800 antialiased selection:bg-indigo-500 selection:text-white">
    
    <!-- Navigation -->
    <header class="navbar">
      <div class="container nav-container">
        <%= link_to root_path, class: "nav-brand" do %>
          <span aria-hidden="true">📚</span>
          <span>BookStore</span>
        <% end %>

        <nav class="nav-links" aria-label="Primary">
          <%= link_to "Browse Books", books_path, class: "btn btn-ghost btn-sm" %>
          <% if user_signed_in? %>
            <%= link_to "Add Book", new_book_path, class: "btn btn-primary btn-sm" %>
            <span class="nav-text hidden sm:block"><%= current_user.email %></span>
            <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline btn-sm" %>
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "btn btn-ghost btn-sm" %>
            <%= link_to "Create Account", new_user_registration_path, class: "btn btn-primary btn-sm" %>
          <% end %>
        </nav>
      </div>
    </header>

    <!-- Flash Messages -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <% if notice %>
        <div class="bg-indigo-50 border-l-4 border-indigo-500 text-indigo-700 p-4 rounded-r shadow-sm animate-fade-in" role="alert">
          <p><%= notice %></p>
        </div>
      <% end %>
      <% if alert %>
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-r shadow-sm animate-fade-in" role="alert">
          <p><%= alert %></p>
        </div>
      <% end %>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-inner">
          <p class="footer-copy">
            &copy; <%= Time.current.year %> BookStore
            <span class="hidden sm:inline">- Curated titles for modern readers.</span>
          </p>
          <div class="footer-actions">
            <%= link_to "All Books", books_path, class: "btn btn-ghost btn-sm" %>
            <% if user_signed_in? %>
              <%= link_to "Add New", new_book_path, class: "btn btn-outline btn-sm" %>
            <% else %>
              <%= link_to "Join", new_user_registration_path, class: "btn btn-outline btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

