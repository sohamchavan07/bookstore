<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>BookStore | Premium Collection</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full flex flex-col font-sans text-slate-800 antialiased selection:bg-indigo-500 selection:text-white">
    
    <!-- Navigation -->
    <header class="navbar">
      <div class="container nav-container">
        <%= link_to root_path, class: "nav-brand" do %>
          <span aria-hidden="true">📚</span>
          <span>BookStore</span>
        <% end %>

        <nav class="nav-links" aria-label="Primary">
          <%= link_to "Browse Books", books_path, class: "btn btn-ghost btn-sm" %>
          <% if user_signed_in? %>
            <%= link_to "Add Book", new_book_path, class: "btn btn-primary btn-sm" %>
            <span class="nav-text hidden sm:block"><%= current_user.email %></span>
            <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline btn-sm" %>
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "btn btn-ghost btn-sm" %>
            <%= link_to "Create Account", new_user_registration_path, class: "btn btn-primary btn-sm" %>
          <% end %>
        </nav>
      </div>
    </header>

    <!-- Flash Messages -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <% if notice %>
        <div class="bg-indigo-50 border-l-4 border-indigo-500 text-indigo-700 p-4 rounded-r shadow-sm animate-fade-in" role="alert">
          <p><%= notice %></p>
        </div>
      <% end %>
      <% if alert %>
        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-r shadow-sm animate-fade-in" role="alert">
          <p><%= alert %></p>
        </div>
      <% end %>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-inner">
          <p class="footer-copy">
            &copy; <%= Time.current.year %> BookStore
            <span class="hidden sm:inline">- Curated titles for modern readers.</span>
          </p>
          <div class="footer-actions">
            <%= link_to "https://github.com/sohamchavan07/bookstore", class: "btn btn-ghost btn-sm github-link", target: "_blank", rel: "noopener" do %>
              <svg class="github-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              <span>GitHub</span>
            <% end %>
            <%= link_to "All Books", books_path, class: "btn btn-ghost btn-sm" %>
            <% if user_signed_in? %>
              <%= link_to "Add New", new_book_path, class: "btn btn-outline btn-sm" %>
            <% else %>
              <%= link_to "Join", new_user_registration_path, class: "btn btn-outline btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
